rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── PRODUCTS COLLECTION ──────────────────
    // Anyone can read products. Only Admin can write.
    match /products/{product} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'admin@D-QueenCart.in';
    }
    
    // ── ORDERS COLLECTION ────────────────────
    // Admin can read/write everything.
    // logged-in users can create orders and read their own.
    match /orders/{order} {
      allow create: if true; // Allow guest checkout creation
      allow read, update, delete: if request.auth != null && request.auth.token.email == 'admin@D-QueenCart.in';
    }
    
    // ── USERS COLLECTION ─────────────────────
    // Users can read/write their own profile.
    // Admin can read everything.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'admin@D-QueenCart.in');
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
  }
}
